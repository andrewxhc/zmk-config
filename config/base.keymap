// Study and make my own combos
// OS based shortcuts (check Miryoku)
// layer names inconsistency

#define DEF 0
#define QWER 1
#define SYM 2
#define NAV 3
#define FN 4
#define NUM 5
#define SYS 6
#define MOUSE 7
#define CON 8
#define BUTTON 9

#define XXX &none
#define ___ &trans

/* Global defaults */

#define QUICK_TAP_MS 175

&sk {
  release-after-ms = <900>;
  quick-release;
};

&sl { // Allow sticky mods to chord across sticky layers.
  ignore-modifiers;
};

&lt {
  flavor = "balanced";
  tapping-term-ms = <200>;
  quick-tap-ms = <QUICK_TAP_MS>;
};

