ZMK_BASE_LAYER(App,
    //╭─────────────╮ ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮ ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮ ╭─────────────╮
        &swapper      &kp LS(TAB)     ___           ___           ___           ___         ,   HY_A          HY_B          HY_C          HY_D          HY_E            ___         ,
    //├─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┤
        OS_TILE_LEFT    ___           ___           ___           ___           ___         ,   HY_F          HY_G          HY_H          HY_I          HY_J            OS_TILE_RIGHT,
    //├─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┤
