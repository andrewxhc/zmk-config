ZMK_BASE_LAYER(Num,
    //╭─────────────╮ ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮ ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮ ╭─────────────╮
        ___             ___           &kp N7        &kp N8        &kp N9        &kp STAR    ,   ___           ___           ___           ___           ___             ___         ,
    //├─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┤
        ___             &kp PLUS      &kp N4        &kp N5        &kp N6        &kp EQUAL   ,   ___           ___           ___           ___           ___             ___         ,
    //├─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤ ├─────────────┤
        ___             &kp MINUS     &kp N1        &kp N2        &kp N3        &kp FSLH    ,   ___           ___           ___           ___           ___             ___         ,
